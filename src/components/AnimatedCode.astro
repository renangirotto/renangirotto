---
import "@fontsource/space-mono";
---

<div aria-hidden="true" class="code">
  <header class="code-header">
    <span class="code-dots"></span>
  </header>
  <div class="code-body">
    <div class="code-block">
      <span class="code-line is-class">.content</span>
      <span class="code-line is-tab-1 is-prop is-delay-prop-color"
        >color: <span class="code-prop-value">white</span></span
      >
      <span
        class="code-line is-tab-1 is-class is-new-block is-delay-class-title"
        >.title</span
      >
      <span class="code-line is-tab-2 is-prop is-delay-props-title"
        >font-size: <span class="code-prop-value">3.75rem</span></span
      >
      <span
        class="code-line is-tab-2 is-class is-new-block is-delay-class-before"
        >&::before</span
      >
      <span class="code-line is-tab-3 is-prop is-delay-props-before"
        >width: <span class="code-prop-value">90%</span></span
      >
      <span class="code-line is-tab-2 is-end-class is-delay-class-before"
      ></span>
      <span class="code-line is-tab-1 is-end-class is-delay-class-title"></span>
      <span class="code-line is-tab-1 is-class is-new-block is-delay-class-text"
        >.text, a</span
      >
      <span class="code-line is-tab-2 is-prop is-delay-props-text-1"
        >font-size: <span class="code-prop-value">1.5rem</span></span
      >
      <span class="code-line is-tab-2 is-prop is-delay-props-text-2"
        >opacity: <span class="code-prop-value">1</span></span
      >
      <span class="code-line is-tab-1 is-end-class is-delay-class-text"></span>
      <span class="code-line is-end-class"></span>
    </div>
  </div>
</div>

<style>
  .code {
    width: 420px;
    height: auto;
    border-radius: 16px;
    background: #2d2e39;
    box-shadow: 2px 2px 10px 4px rgba(31, 32, 38, 0.5);
    opacity: 0;
    visibility: hidden;
    transform: translateY(0px);
    transition: height 0.1s;
    animation: animate-code-block 0.3s linear 0.5s forwards;
  }

  .code-header {
    box-sizing: border-box;
    display: flex;
    width: 100%;
    padding: 16px;
  }

  .code-dots {
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    position: relative;
    background: #f35d5b;

    &::before,
    &::after {
      content: "";
      display: block;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      position: absolute;
    }

    &::before {
      left: calc(100% + 8px);
      background: #f8bc3a;
    }

    &::after {
      left: calc(200% + 16px);
      background: #44cc45;
    }
  }

  .code-body {
    padding-inline: 32px;
    padding-block: 32px 48px;
  }

  .code-block {
    display: flex;
    flex-direction: column;
  }

  .code-line {
    box-sizing: border-box;
    display: block;
    width: 0%;
    margin-block-end: 12px;
    font-family: "Space Mono", sans-serif;
    line-height: 1.2;
    color: #d5ced9;
    white-space: nowrap;
    overflow: hidden;
    transition: height 0.25s;
    animation: animate-code-line 1.5s linear 0.8s forwards;

    &.is-delay-prop-color {
      animation-delay: 1s;
    }

    &.is-delay-class-title {
      animation-delay: 1.5s;
    }

    &.is-delay-class-before {
      animation-delay: 1.75s;
    }

    &.is-delay-class-text {
      animation-delay: 2s;
    }

    &.is-delay-props-title {
      animation-delay: 2.25s;
    }

    &.is-delay-props-before {
      animation-delay: 2.5s;
    }

    &.is-delay-props-text-1 {
      animation-delay: 2.75s;
    }

    &.is-delay-props-text-2 {
      animation-delay: 3s;
    }

    &.is-class {
      color: #ffe66d;

      &::after {
        content: " {";
      }
    }

    &.is-end-class {
      color: #ffe66d;

      &::after {
        content: "}";
      }
    }

    &.is-prop {
      &::after {
        content: ";";
      }
    }

    &.is-new-block {
      margin-block-start: 12px;
    }

    &.is-tab-1 {
      padding-inline-start: 16px;
    }

    &.is-tab-2 {
      padding-inline-start: 32px;
    }

    &.is-tab-3 {
      padding-inline-start: 48px;
    }
  }

  .code-prop-value {
    color: #f38d24;
  }

  @keyframes animate-code-block {
    0% {
      opacity: 0;
      visibility: hidden;
      transform: translateY(16px);
    }
    100% {
      opacity: 1;
      visibility: visible;
      transform: translateY(0px);
    }
  }

  @keyframes animate-code-line {
    0% {
      width: 0px;
    }
    100% {
      width: 100%;
    }
  }
</style>
